# =============================================================================
# .env.example — copy to .env and fill in your values
#
#   cp .env.example .env
#
# .env is in .gitignore — never commit real values.
# This file IS committed so teammates know what variables are required.
# =============================================================================

# Port Nginx listens on (default: 80)
NGINX_PORT=8080

# Redis cache TTL in seconds for /api/data responses (default: 30)
REDIS_TTL=30

# Redis max memory — uses LRU eviction when full (default: 128mb)
REDIS_MAXMEM=128mb

# Application environment label shown in /api/data response
APP_ENV=production

# Container image coordinates for `docker compose pull` / `docker buildx push`
# Replace with your Docker Hub username or GitHub org
IMAGE_REGISTRY=ghcr.io
IMAGE_REPO=youruser/miniplatform-app
IMAGE_TAG=latest
